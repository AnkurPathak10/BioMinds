generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Users (synced from Clerk via webhook) ──
model User {
  id          String   @id @default(cuid())
  clerkId     String   @unique @map("clerk_id")
  email       String   @unique
  name        String?
  imageUrl    String?  @map("image_url")
  role        String   @default("student")
  institution String?
  plan        String   @default("free")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  notebooks      Notebook[]
  paperLibraries PaperLibrary[]
  debugSessions  DebugSession[]

  @@map("users")
}

// ── Lab Notebooks ──
model Notebook {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  title       String
  description String?
  emoji       String   @default("🧪")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries Entry[]

  @@index([userId])
  @@map("notebooks")
}

// ── Notebook Entries ──
model Entry {
  id             String    @id @default(cuid())
  notebookId     String    @map("notebook_id")
  title          String
  hypothesis     String?
  materials      String?
  procedure      String?
  observations   String?
  results        String?
  conclusion     String?
  rawVoiceText   String?   @map("raw_voice_text")
  source         String    @default("typed")
  tags           String[]  @default([])
  experimentDate DateTime? @map("experiment_date")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  notebook Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)

  @@index([notebookId])
  @@map("entries")
}

// ── Paper Libraries ──
model PaperLibrary {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  papers Paper[]

  @@index([userId])
  @@map("paper_libraries")
}

// ── Papers ──
model Paper {
  id         String   @id @default(cuid())
  libraryId  String   @map("library_id")
  title      String
  fileName   String?  @map("file_name")
  fileSize   Int?     @map("file_size")
  numPages   Int      @default(0) @map("num_pages")
  wordCount  Int      @default(0) @map("word_count")
  preview    String?
  status     String   @default("processing")
  chunkCount Int      @default(0) @map("chunk_count")
  createdAt  DateTime @default(now()) @map("created_at")

  library PaperLibrary @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  chunks  PaperChunk[]

  @@index([libraryId])
  @@map("papers")
}

// ── Paper Chunks ──
model PaperChunk {
  id         String @id @default(cuid())
  paperId    String @map("paper_id")
  chunkIndex Int    @map("chunk_index")
  content    String

  paper Paper @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@index([paperId])
  @@map("paper_chunks")
}

// ── Debug Sessions ──
model DebugSession {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  description     String
  expectedResult  String?  @map("expected_result")
  protocol        String?
  imageCount      Int      @default(0) @map("image_count")
  createdAt       DateTime @default(now()) @map("created_at")

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  diagnoses Diagnosis[]

  @@index([userId])
  @@map("debug_sessions")
}

// ── Diagnoses ──
model Diagnosis {
  id             String @id @default(cuid())
  sessionId      String @map("session_id")
  rank           Int
  title          String
  probability    String
  explanation    String
  suggestedFix   String @map("suggested_fix")
  possibleCauses String[] @default([]) @map("possible_causes")

  session DebugSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("diagnoses")
}
